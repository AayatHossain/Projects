# Copy this file to .env. All EXPO_PUBLIC_ vars are embedded in the app bundle,
# so NEVER put secrets here. AI keys live on the backend (backend/.env), not here.

# Backend base URL. Leave unset for local dev (auto-detected from Metro).
# For a standalone/EAS build, set it to your hosted backend (put it in eas.json
# env, since .env is not uploaded to EAS cloud builds):
# EXPO_PUBLIC_API_URL=https://your-service.onrender.com
