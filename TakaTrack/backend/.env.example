# Copy to .env and fill in. .env is gitignored — never commit secrets.

# --- Firebase Realtime Database ---
# Path to the service-account JSON (relative to backend/ or absolute).
FIREBASE_CREDENTIALS=serviceAccountKey.json
FIREBASE_DB_URL=https://quickaid-70d9b-default-rtdb.firebaseio.com

# --- Auth ---
# Generate a strong random value for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me

# Comma-separated CORS origins (use * for local dev).
CORS_ORIGINS=*
